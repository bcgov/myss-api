# Local development environment for myss-api.
# Copy to `.env` (gitignored) and adjust as needed.
# Do not put real production secrets here.

# --- Environment ---
ENVIRONMENT=local

# --- Database ---
# SQLite default works out of the box for local dev.
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# PostgreSQL for parity with prod:
# DATABASE_URL=postgresql+asyncpg://myss:myss@localhost:5432/myss

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# Any string is fine for local dev; validated in non-local environments.
JWT_SECRET=change-me-for-local-dev-only

# --- CORS ---
# Fails closed (empty list) outside local/test if unset.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Webhooks ---
AV_WEBHOOK_SECRET=local-dev-av-secret

# --- ICM / Siebel ---
# Leave blank for local dev — the mock ICM clients activate when
# ENVIRONMENT is `local` or `test` AND ICM_BASE_URL is empty.
ICM_BASE_URL=
ICM_CLIENT_ID=
ICM_CLIENT_SECRET=
ICM_TOKEN_URL=

# --- Seed data ---
# JWT expiry (days) for tokens produced by scripts/seed_db.py.
# Default 1 day for local dev; the OpenShift test-env seed Job sets 90.
# SEED_TOKEN_TTL_DAYS=1
